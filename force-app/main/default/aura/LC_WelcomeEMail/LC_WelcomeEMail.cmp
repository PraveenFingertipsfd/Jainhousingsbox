<aura:component controller="BookingController" 
                implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickActionWithoutHeader" 
                access="global">
    <aura:attribute name="emailContent" type="String" />
    <aura:attribute name="recepients" type="String" />
    <aura:attribute name="loggedInUserName" type="String" />
    <aura:attribute name="loggedInUserPhone" type="String" />
    <aura:attribute name="loggedInUserEmail" type="String" />
    <aura:attribute name="record" type="Object" /> 
    <aura:attribute name="files" type="List" />
    <aura:attribute name="filesIDS" type="List" />
    <aura:handler name="fileUploadEvent" event="c:fileUploadEvent" action="{!c.handleFileUpload}" />
    <aura:attribute name="bookingFormPdfUrl" type="String" />
    
    <aura:attribute name="isProcessing" type="Boolean" default="false"/> <!-- added by karthik 25/07 -->
    <aura:attribute name="documentList" type="List" /> <!-- List of {name, url} -->
    <aura:attribute name="showPdfModal" type="Boolean" default="false" />
    <aura:attribute name="activePdfUrl" type="String" />
    <aura:attribute name="activePdfName" type="String" />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <aura:html tag="style">
        .slds-modal__container { 
        max-width: 50rem !important;
        width: 75% !important;
        } 
        .cuf-content {
        padding: 0 0rem !important;
        }
        .slds-p-around--medium {
        padding: 0rem !important;
        }
        .slds-modal__content {
        height: unset !important;
        max-height: unset !important;
        }
        .closeIcon {
        display: none;
        }
        .slds-col {
        margin-left: 15px;
        }
        .custom-textarea {
        --sds-c-textarea-sizing-min-height: 300px;
        }
    </aura:html>
    
    <aura:if isTrue="{!!v.showPdfModal}">
        <div style="text-align: center; margin-top: 20px;">
            <h1 style="font-size: 20px; color: white; background: darkgray; border-radius: 20px; margin-right: 50px; margin-left: 50px;"><b>Jain Housing Welcome Mail</b></h1>
        </div><br/><br/>
        
        <div style="width: 100%; max-width: 700px; margin: 0 auto;">
            <lightning:inputRichText class="custom-textarea" aura:id="emailContent"
                                     placeholder="Review and edit email content"
                                     value="{!v.emailContent}"   />

            <aura:if isTrue="{!not(empty(v.documentList))}">
                <div style="margin-top: 20px; margin-left: 20px;">
                    <h3 style="color: currentcolor; font-size: 15px; font-weight: 700; padding-bottom: 10px;">Attached Files:</h3>
                    <aura:iteration items="{!v.documentList}" var="doc">
                        <lightning:icon iconName="doctype:pdf" alternativeText="PDF" size="small" /> &nbsp;
                        <a href="javascript:void(0);" onclick="{!c.previewDocument}" data-url="{!doc.url}" data-name="{!doc.name}"
                           style="font-size: 16px; color: #0070d2; text-decoration: underline;">
                            {!doc.name}
                        </a><br/>
                    </aura:iteration>
                </div><br/>
            </aura:if>
            
            <!--<c:photoUploadComponent recordId="{!v.recordId}" filesIds="{!v.filesIDS}" />-->
            
            <div class="modal-footer slds-modal__footer slds-size_1-of-1"  style="box-shadow: none; text-align: center;border: 0px;">
                <ui:button class="custom-round-button slds-button slds-button--neutral" label="Cancel" press="{!c.Cancel}" disabled="{!v.isProcessing}"/>
                <button class="custom-round-button slds-button slds-button_brand" 
                        onclick="{!c.sendEmail}" 
                        disabled="{!v.isProcessing}">
                    <aura:if isTrue="{!v.isProcessing}">
                        <lightning:spinner variant="brand" size="small" class="slds-m-right_x-small" />
                        Sending...
                        <aura:set attribute="else">
                            Send Email
                        </aura:set>
                    </aura:if>
                </button>

            </div>
        </div>
    </aura:if>
    
    <aura:if isTrue="{!v.showPdfModal}">
        <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open slds-modal_large">
            <div class="slds-modal__container">
                <header class="slds-modal__header">
                    <lightning:buttonIcon iconName="utility:close" class="slds-modal__close" onclick="{!c.closePdfModal}" alternativeText="Close"/>
                    <h2 class="slds-text-heading_medium">{!v.activePdfName}</h2>
                </header>
                <div class="slds-modal__content" style="height: 80vh;">
                    <iframe src="{!v.activePdfUrl}" width="100%" height="500px" style="border: none;"></iframe>
                </div>
                <footer class="slds-modal__footer">
                    <lightning:button variant="neutral" label="Close" onclick="{!c.closePdfModal}" />
                </footer>
            </div>
        </section>
        <!--<div class="slds-backdrop slds-backdrop_open"></div>-->
    </aura:if>
    
</aura:component>