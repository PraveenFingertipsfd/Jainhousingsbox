<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId" controller="LightningFileUploadHandler1" access="global">
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="uploadedFiles" type="List" default="[]" />
    <aura:attribute name="isUploading" type="Boolean" default="false" />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <div class="slds-card slds-p-around_medium">
        <lightning:fileUpload 
            label="Upload File" 
            multiple="false" 
            recordId="{!v.recordId}" 
            onuploadfinished="{!c.handleUploadFinished}" 
            accept=".pdf,.jpg,.jpeg,.png" />
        
        <aura:if isTrue="{!v.isUploading}">
            <div class="slds-spinner_container">
                <div class="slds-spinner slds-spinner_medium" role="status">
                    <span class="slds-assistive-text">Uploading...</span>
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
            </div>
        </aura:if>

        <aura:if isTrue="{!not(empty(v.uploadedFiles))}">
            <div class="slds-m-top_medium">
                <p class="slds-text-title_caps">Uploaded File:</p>
                <aura:iteration items="{!v.uploadedFiles}" var="file">
                    <div>
                        <a href="javascript:void(0)" onclick="{!c.previewFile}" data-id="{!file.documentId}">{!file.name}</a>
                    </div>
                </aura:iteration>
            </div>
        </aura:if>
    </div>
</aura:component>