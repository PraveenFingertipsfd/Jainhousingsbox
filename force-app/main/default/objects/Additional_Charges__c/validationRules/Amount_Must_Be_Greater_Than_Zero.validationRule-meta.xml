<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amount_Must_Be_Greater_Than_Zero</fullName>
    <active>true</active>
    <description>Ensures that the Amount field is greater than 0 when creating or editing Additional Charges.</description>
    <errorConditionFormula>OR(ISBLANK(Amount__c), Amount__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>Amount__c</errorDisplayField>
    <errorMessage>Amount must be greater than 0.</errorMessage>
</ValidationRule>
