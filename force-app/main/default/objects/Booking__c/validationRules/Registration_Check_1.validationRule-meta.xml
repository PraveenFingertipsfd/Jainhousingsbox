<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Registration_Check_1</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Stage__c, &apos;Possession&apos;),
    NOT(ISPICKVAL(Finance_Approval1__c, &apos;Approved&apos;))
)</errorConditionFormula>
