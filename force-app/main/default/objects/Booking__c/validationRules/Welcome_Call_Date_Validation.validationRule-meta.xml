<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Welcome_Call_Date_Validation</fullName>
    <active>true</active>
    <description>validation for welcome call date</description>
    <errorConditionFormula>DATEVALUE(Welcome_Call_Date__c) &gt; TODAY()</errorConditionFormula>
    <errorDisplayField>Welcome_Call_Date__c</errorDisplayField>
    <errorMessage>Future dates are not allowed. Please select today or a past date.</errorMessage>
</ValidationRule>
