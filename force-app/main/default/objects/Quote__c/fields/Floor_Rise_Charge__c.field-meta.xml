<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Floor_Rise_Charge__c</fullName>
    <formula>IF(
    ISPICKVAL(Floor__c, &quot;G&quot;),
    0,  /* For &quot;G&quot;, no calculation or return 0 or another value */
    CASE(
        Floor__c,
        &quot;1&quot;, 15 * 0,
        &quot;2&quot;, 15 * 0,
        &quot;3&quot;, 15 * 0,
        &quot;4&quot;, 15 * 0,
        &quot;5&quot;, 15 * 5,
        &quot;6&quot;, 15 * 6,
        &quot;7&quot;, 15 * 7,
        &quot;8&quot;, 15 * 8,
        &quot;9&quot;, 15 * 9,
        &quot;10&quot;, 15 * 10,
        &quot;11&quot;, 15 * 11,
        &quot;12&quot;, 15 * 12,
