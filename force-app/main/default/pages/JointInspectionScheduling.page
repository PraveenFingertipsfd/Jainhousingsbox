<apex:page controller="JointInspectionSchedulingController" showHeader="false" sidebar="false" standardStylesheets="false" docType="html-5.0">
    
    <style>
        :root {
        --primary-color: #4a6cf7;
        --primary-hover: #3a5ce4;
        --text-color: #2d3748;
        --light-gray: #f7fafc;
        --border-color: #e2e8f0;
        --success-color: #48bb78;
        --error-color: #f56565;
        --warning-color: #ed8936;
        }
        
        body {
        font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        max-width: 640px;
        margin: 0 auto;
        padding: 2rem 1rem;
        color: var(--text-color);
        line-height: 1.5;
        background-color: #f9fafb;
        }
        
        .form-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        padding: 2rem;
        margin-top: 1.5rem;
        }
        
        h2 {
        color: var(--primary-color);
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 1.5rem;
        text-align: center;
        }
        
        .input-field {
        margin-top: 1.5rem;
        }
        
        label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: var(--text-color);
        }
        
        .form-control {
        padding: 0.75rem;
        width: 100%;
        box-sizing: border-box;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        }
        
        .form-control:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(74, 108, 247, 0.1);
        }
        
        .readonly-field {
        padding: 0.75rem;
        background: var(--light-gray);
        border-radius: 8px;
        border: 1px solid var(--border-color);
        color: var(--text-color);
        }
        
        .btn {
        background: var(--primary-color);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 500;
        width: 100%;
        transition: background-color 0.2s, transform 0.1s;
        }
        
        .btn:hover {
        background: var(--primary-hover);
        }
        
        .btn:active {
        transform: translateY(1px);
        }
        
        /* Status message boxes */
        .status-box {
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border-radius: 8px;
        text-align: center;
        font-weight: 500;
        }
        
        .status-box.expired {
        background: #fff5f5;
        border: 1px solid var(--error-color);
        color: var(--error-color);
        }
        
        .status-box.scheduled {
        background: #f0fff4;
        border: 1px solid var(--success-color);
        color: var(--success-color);
        }
        
        .status-icon {
        font-size: 2rem;
        margin-bottom: 1rem;
        }
        
        .divider {
        height: 1px;
        background: var(--border-color);
        margin: 1.5rem 0;
        }
        
        @media (min-width: 640px) {
        body {
        padding: 3rem 0;
        }
        
        .btn {
        width: auto;
        }
        }
        
        .info-note {
            background-color: #ebf8ff;
            border-left: 4px solid var(--info-color);
            padding: 1rem;
            margin: 1rem 0;
            border-radius: 0 4px 4px 0;
            font-size: 0.9rem;
            color: var(--text-color);
        }
    </style>
    <style>
        /* Add this to your existing styles */
        .datetime-row {
        display: flex;
        gap: 16px; /* Space between date and time inputs */
        margin-bottom: 1.5rem;
        }
        
        .datetime-column {
        flex: 1; /* Each column takes equal space */
        min-width: 0; /* Prevent flex items from overflowing */
        }
        
        /* Make sure inputs take full width of their container */
        .datetime-column .form-control {
        width: 100%;
        }
        
        /* Responsive adjustment for smaller screens */
        @media (max-width: 480px) {
        .datetime-row {
        flex-direction: column;
        gap: 1rem;
        }
        }
        
        .error-text {
        color: #f56565;
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
        }
        
        .valid-text {
        display: none;
        }
    </style>   
    <apex:form id="mainForm">
        <div class="form-container">
            <h2>Schedule Joint Inspection</h2>
            
            <!-- Link expired message -->
            <apex:outputPanel rendered="{!isExpired}">
                <div class="status-box expired">
                    <div class="status-icon">⚠️</div>
                    <h3>Link Expired</h3>
                    <p>This scheduling link has expired. Please contact customer support to schedule your inspection.</p>
                </div>
            </apex:outputPanel>
            
            <!-- Success message (shown only on first submission) -->
            <apex:outputPanel rendered="{!isSuccess}">
                <div class="status-box scheduled">
                    <div class="status-icon">✓</div>
                    <h3>Successfully Scheduled!</h3>
                    <p>Your joint inspection has been scheduled for {!existingInspectionDate}.</p>
                </div>
            </apex:outputPanel>
            
            <!-- Already scheduled message (shown on reload) -->
            <apex:outputPanel rendered="{!alreadyResponded && !isSuccess}">
                <div class="status-box scheduled">
                    <div class="status-icon">✓</div>
                    <h3>Inspection Already Scheduled</h3>
                    <p>Your joint inspection was already scheduled for {!existingInspectionDate}.</p>
                </div>
            </apex:outputPanel>
            
            <apex:outputPanel rendered="{!showForm}">
                <div class="input-field">
                    <label>Project</label>
                    <div class="readonly-field">
                        {!projectName}
                    </div>
                </div>
                
                <div class="input-field">
                    <label>Unit</label>
                    <div class="readonly-field">
                        {!unitName}
                    </div>
                </div>
                
                <div class="divider"></div>
                <div class="info-note">
                    <strong>Note:</strong> Inspections can only be scheduled on weekdays (Monday-Saturday) excluding public holidays, between 10:00 AM - 4:00 PM.
                </div>
                <div class="datetime-row">
                    <div class="datetime-column input-field">
                        <label for="inspectionDate">Preferred Date</label>
                        <apex:input type="date" value="{!inspectionDate}" styleClass="form-control" required="true" id="inspectionDate"/>
                        <span class="error-text" style="display:{!IF(NOT isDateValid, 'block', 'none')}">
                            {!dateValidationMessage}
                        </span>
                    </div>
                    
                    <div class="datetime-column input-field">
                        <label for="inspectionTime">Preferred Time</label>
                        <apex:input type="time" value="{!inspectionTime}" styleClass="form-control" required="true" id="inspectionTime"/>
                        <span class="error-text" style="display:{!IF(NOT isTimeValid, 'block', 'none')}">
                            Inspection time must be between 10 AM - 4 PM
                        </span>
                    </div>
                </div>
                <div class="input-field" style="margin-top: 2rem; text-align: center;">
                    <apex:commandButton value="Schedule Inspection" action="{!scheduleInspection}" styleClass="btn" style="display: inline-block;"/>
                </div>
            </apex:outputPanel>
        </div>
    </apex:form>
</apex:page>